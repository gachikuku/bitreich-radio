#!/bin/sh

# bitreich-radio: tune in to Bitreich Radio.
# POSIX shell. Requires sacc + mpv.

RADIO_DIR="$(cd "$(dirname "$0")" && pwd)"
export PATH="${RADIO_DIR}:${PATH}"

if [ ! -x "${RADIO_DIR}/sacc" ]; then
    echo "sacc not found. Run ./install.sh first." >&2
    exit 1
fi

pidfile="${XDG_RUNTIME_DIR:-/tmp}/sacc-mpv.pid"

cleanup() {
    if [ -f "$pidfile" ]; then
        pid=$(cat "$pidfile" 2>/dev/null)
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null
        fi
        rm -f "$pidfile"
    fi
}

trap cleanup EXIT INT TERM HUP
"${RADIO_DIR}/sacc" "gophers://bitreich.org/1/radio/lawn"
cleanup
